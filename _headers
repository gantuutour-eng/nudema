# Cloudflare Pages — HTML-ийг кэшлүүлэхгүй.
# Шинэчлэлт хийхэд хуучин хуудас утсан дээр үлдэхээс сэргийлнэ
# (ялангуяа апп доторх хөтчүүд түрэмгий кэшилдэг).

/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()

/
  Cache-Control: no-cache, must-revalidate

/index.html
  Cache-Control: no-cache, must-revalidate

/*.html
  Cache-Control: no-cache, must-revalidate

# Cloudflare Pages нь .html хаягийг өргөтгөлгүй .dc хаяг руу шилжүүлдэг.
/*.dc
  Cache-Control: no-cache, must-revalidate

# Runtime ба төлөв өөрчлөгддөг JS
/nudema-store.js
  Cache-Control: no-cache, must-revalidate

/support.js
  Cache-Control: no-cache, must-revalidate

/assets/vendor/*
  Cache-Control: public, max-age=31536000, immutable

/nudema-menu.js
  Cache-Control: no-cache, must-revalidate

/nudema-auth.js
  Cache-Control: no-cache, must-revalidate

/auth-page.css
  Cache-Control: no-cache, must-revalidate
